# =============================================================================
# PTE Benchmark — API Keys & Site Credentials (EXAMPLE TEMPLATE)
# =============================================================================
# This file is committed to the repo as a reference. It contains no real keys.
#
# To use:
#   cp config/.env.example config/.env
#   Fill in config/.env with your actual keys.
#
# The active provider is set in config/config.yaml under:
#   agent_llm_provider: openai       # or: google-gla, anthropic
#   agent_llm_model:    gpt-4.1      # or: gemini-2.5-flash, claude-3-7-sonnet-...
#
# config/.env is loaded automatically by BaseAgentRunner at test startup.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider Keys (fill in one, leave others blank)
# -----------------------------------------------------------------------------

# OpenAI  (agent_llm_provider: openai)
OPENAI_API_KEY=

# Google Gemini / AI Studio  (agent_llm_provider: google-gla)
GEMINI_API_KEY=

# Anthropic  (agent_llm_provider: anthropic)
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# WebArena Site Credentials (defaults work with standard WebArena Docker setup)
# -----------------------------------------------------------------------------

# GitLab
GITLAB_DOMAIN=http://localhost:8023
GITLAB_USERNAME=byteblaze
GITLAB_PASSWORD=hello1234

# Reddit (Postmill)
REDDIT_DOMAIN=http://localhost:9999
REDDIT_USERNAME=MarvelsGrantMan136
REDDIT_PASSWORD=test1234

# Shopping
WEBARENA_BASE_URL=http://ec2-18-218-205-96.us-east-2.compute.amazonaws.com:8082/
