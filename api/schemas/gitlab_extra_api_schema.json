{
    "swagger": "2.0",
    "info": {
        "title": "GitLab Extra API",
        "description": "Custom endpoints for GitLab that aren't covered by the REST API (e.g. RSS/feed token).",
        "version": "1.0.0"
    },
    "host": "127.0.0.1:7792",
    "basePath": "/",
    "schemes": ["http"],
    "paths": {
        "/rss_token": {
            "get": {
                "summary": "Get current RSS/feed token",
                "description": "Read the current GitLab user's RSS/Atom feed token from their profile page. Logs in with default credentials from environment.",
                "operationId": "rss_token",
                "produces": ["application/json"],
                "responses": {
                    "200": {
                        "description": "Current RSS token",
                        "schema": {
                            "type": "object",
                            "required": ["success"],
                            "properties": {
                                "success": {"type": "boolean"},
                                "token": {"type": "string", "description": "The user's RSS/feed token"},
                                "error_message": {"type": "string"}
                            }
                        }
                    }
                }
            }
        },
        "/reset_rss_token": {
            "post": {
                "summary": "Reset (regenerate) the RSS/feed token",
                "description": "Reset the current GitLab user's RSS/Atom feed token and return the newly generated value. The previous token is immediately invalidated.",
                "operationId": "reset_rss_token",
                "produces": ["application/json"],
                "responses": {
                    "200": {
                        "description": "Newly generated RSS token",
                        "schema": {
                            "type": "object",
                            "required": ["success"],
                            "properties": {
                                "success": {"type": "boolean"},
                                "token": {"type": "string", "description": "The newly generated RSS/feed token"},
                                "error_message": {"type": "string"}
                            }
                        }
                    }
                }
            }
        }
    }
}
